{
	"name": "PHP",
	"build": {
		"dockerfile": "./Dockerfile",
		"context": ".."
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"bmewburn.vscode-intelephense-client",
				"xdebug.php-pack",
				"devsense.phptools-vscode",
				"mehedidracula.php-namespace-resolver",
				"devsense.composer-php-vscode",
				"phiter.phpstorm-snippets"
			]
		}
	},
	"forwardPorts": [
		8080
	],
	"remoteUser": "root"
}
